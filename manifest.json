{
  "manifest_version": 3,
  "name": "网易云音乐淡出歌单",
  "version": "1.0.0",
  "description": "自动将手动跳过的歌曲加入淡出歌单",
  "permissions": [
    "cookies",
    "storage",
    "webRequest",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "*://music.163.com/*",
    "*://*.music.126.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://music.163.com/*"],
      "js": [
        "utils/logger.js",
        "ui/toast.js",
        "content.js"
      ],
      "css": ["ui/toast.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "淡出歌单"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
